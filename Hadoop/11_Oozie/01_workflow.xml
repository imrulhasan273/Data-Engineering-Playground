<?xml version="1.0" encoding="UTF-8"?>
<!--
  01_workflow.xml — Oozie Workflow: MapReduce → Hive → Shell actions in sequence

  Submit: oozie job -oozie http://localhost:11000/oozie -config job.properties -run
  Status: oozie job -oozie http://localhost:11000/oozie -info <job-id>
-->
<workflow-app name="wordcount-pipeline" xmlns="uri:oozie:workflow:0.5">

    <!-- ── Start → First action ────────────────────────────────────────────── -->
    <start to="prepare-input"/>

    <!-- ── Action 1: Shell — prepare HDFS directories ────────────────────────── -->
    <action name="prepare-input">
        <shell xmlns="uri:oozie:shell-action:0.3">
            <job-tracker>${jobTracker}</job-tracker>
            <name-node>${nameNode}</name-node>
            <exec>bash</exec>
            <argument>-c</argument>
            <argument>
                hdfs dfs -mkdir -p ${outputDir} &amp;&amp;
                echo "Directories ready"
            </argument>
            <capture-output/>
        </shell>
        <ok    to="mapreduce-wordcount"/>
        <error to="fail"/>
    </action>

    <!-- ── Action 2: MapReduce — word count ───────────────────────────────── -->
    <action name="mapreduce-wordcount">
        <map-reduce>
            <job-tracker>${jobTracker}</job-tracker>
            <name-node>${nameNode}</name-node>

            <!-- Delete output before running (idempotent) -->
            <prepare>
                <delete path="${outputDir}/wordcount"/>
            </prepare>

            <configuration>
                <property>
                    <name>mapred.mapper.class</name>
                    <value>org.apache.hadoop.mapreduce.examples.WordCount$TokenizerMapper</value>
                </property>
                <property>
                    <name>mapred.reducer.class</name>
                    <value>org.apache.hadoop.mapreduce.examples.WordCount$IntSumReducer</value>
                </property>
                <property>
                    <name>mapred.input.dir</name>
                    <value>${inputDir}</value>
                </property>
                <property>
                    <name>mapred.output.dir</name>
                    <value>${outputDir}/wordcount</value>
                </property>
                <property>
                    <name>mapreduce.job.queuename</name>
                    <value>default</value>
                </property>
            </configuration>
        </map-reduce>
        <ok    to="hive-load"/>
        <error to="fail"/>
    </action>

    <!-- ── Action 3: Hive — load results into Hive table ─────────────────── -->
    <action name="hive-load">
        <hive xmlns="uri:oozie:hive-action:0.6">
            <job-tracker>${jobTracker}</job-tracker>
            <name-node>${nameNode}</name-node>

            <script>${workflowAppPath}/scripts/load_wordcount.hql</script>

            <!-- Pass parameters to the HQL script -->
            <param>INPUT=${outputDir}/wordcount</param>
            <param>DB_NAME=${dbName}</param>
        </hive>
        <ok    to="notify-complete"/>
        <error to="fail"/>
    </action>

    <!-- ── Action 4: Shell — send completion notification ─────────────────── -->
    <action name="notify-complete">
        <shell xmlns="uri:oozie:shell-action:0.3">
            <job-tracker>${jobTracker}</job-tracker>
            <name-node>${nameNode}</name-node>
            <exec>bash</exec>
            <argument>-c</argument>
            <argument>echo "Workflow completed at $(date). Output: ${outputDir}" | tee /tmp/workflow_done.txt</argument>
        </shell>
        <ok    to="end"/>
        <error to="fail"/>
    </action>

    <!-- ── End ────────────────────────────────────────────────────────────── -->
    <end name="end"/>

    <!-- ── Fail (kill node) ───────────────────────────────────────────────── -->
    <kill name="fail">
        <message>Workflow failed, error message: ${wf:errorMessage(wf:lastErrorNode())}</message>
    </kill>

</workflow-app>
