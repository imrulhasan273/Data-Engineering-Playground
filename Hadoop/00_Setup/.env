# Hadoop Cluster Environment Variables

# Hadoop version
HADOOP_VERSION=3.3.6

# HDFS Web UI
NAMENODE_HTTP_PORT=9870
NAMENODE_RPC_PORT=9000

# YARN Web UI
YARN_RESOURCEMANAGER_PORT=8088
YARN_NODEMANAGER_PORT=8042

# MapReduce History Server
MR_HISTORY_PORT=19888

# Hive
HIVE_SERVER2_PORT=10000
HIVE_WEBUI_PORT=10002

# HBase
HBASE_MASTER_PORT=16000
HBASE_MASTER_WEBUI_PORT=16010
HBASE_REGIONSERVER_PORT=16020
ZOOKEEPER_PORT=2181

# Spark
SPARK_HISTORY_PORT=18080

# MySQL (Hive Metastore)
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=hivepassword
MYSQL_DATABASE=hive_metastore
MYSQL_USER=hive
MYSQL_PASSWORD=hive

# Resource allocation (adjust based on your machine)
YARN_NODEMANAGER_MEMORY_MB=2048
YARN_NODEMANAGER_VCORES=2
